# Local .terraform directories
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfstate.lock.info

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (contain sensitive data)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Swap files
*.swp
*.swo
*~

# Log files
*.log

# Backup files
*.bak
*.backup

# OS metadata
.DS_Store
Thumbs.db
